# Factory AI Navi — 환경변수 설정
# 이 파일을 복사해서 .env 로 사용: cp .env.example .env

# ── Layer 1/2: DB ──────────────────────────────────────────
DATABASE_URL=sqlite:///dev_local.db
USE_MOCK_DATA=false

# ── Layer 2: LLM 선택 (claude 또는 gemini) ──────────────────
LLM_PROVIDER=gemini

# Claude (LLM_PROVIDER=claude 일 때)
# 발급: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-여기에_실제_키_입력

# Gemini (LLM_PROVIDER=gemini 일 때)
# 발급: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=여기에_실제_키_입력
GEMINI_MODEL=gemini-2.5-flash-lite

# ── Layer 2: 네이버 검색 API (RAG) ──────────────────────────
# https://developers.naver.com/apps 에서 발급
NAVER_CLIENT_ID=여기에_실제_키_입력
NAVER_CLIENT_SECRET=여기에_실제_키_입력

# ── Layer 2: Tavily API (선택) ──────────────────────────────
# TAVILY_API_KEY=tvly-여기에_실제_키_입력

# ── Layer 3: 서버 설정 ───────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
